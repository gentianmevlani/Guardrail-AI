  @@index([eventType, timestamp])
  @@index([orgId, timestamp])
  @@index([severity, timestamp])
  @@index([ip, timestamp])
  @@map("security_events")
}

// ==========================================
// REPORTS
// ==========================================

model Report {
  id          String   @id @default(cuid())
  projectId   String?  @map("project_id")
  userId      String   @map("user_id")
  type        String   // security, compliance, performance, etc.
  format      String   // pdf, html, json
  content     String   @db.Text
  filename    String?
  metadata    Json?
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([projectId])
  @@index([userId])
  @@index([type])
  @@map("reports")
}

// ==========================================
// COMPLIANCE & PRIVACY
// ==========================================

model ConsentPreferences {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  necessary   Boolean  @default(true)  // Always required for operation
  analytics   Boolean  @default(false) // Google Analytics, etc.
  marketing   Boolean  @default(false) // Email marketing, ads
  functional  Boolean  @default(false) // Preferences, personalization
  source      String   @default("web") // web, mobile, api
  ipHash      String?  @map("ip_hash") // Hashed IP for audit
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId])
  @@index([updatedAt])
  @@map("consent_preferences")
}

model LegalAcceptance {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  docType     String   @map("doc_type") // 'terms' | 'privacy'
  version     String   // Version of the document
  acceptedAt  DateTime @default(now()) @map("accepted_at")
  ipHash      String?  @map("ip_hash") // Hashed IP for audit
  userAgent   String?  @map("user_agent") // User agent for audit
  locale      String?  // User's locale (en, es, etc.)
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, docType])
  @@index([userId, docType])
  @@index([acceptedAt])
  @@map("legal_acceptances")
}

model GdprJob {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  type          String   // 'EXPORT' | 'DELETE'
  status        String   @default("pending") // 'pending' | 'processing' | 'completed' | 'failed'
  createdAt     DateTime @default(now()) @map("created_at")
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  artifactPath  String?  @map("artifact_path") // Path to export file
  signedUrl     String?  // Pre-signed URL for download
  failureReason String?  @map("failure_reason")
  metadata      Json?    // Additional job data
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, type])
  @@index([status])
  @@index([createdAt])
  @@map("gdpr_jobs")
}

model GdprAuditLog {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  action      String   // 'data_exported' | 'account_deleted' | 'data_anonymized' | 'consent_updated'
  actorUserId String?  @map("actor_user_id") // Who performed the action (null for automated)
  timestamp   DateTime @default(now())
  metadata    Json?    // Action details
  
  // Relations
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, timestamp])
  @@index([action, timestamp])
  @@map("gdpr_audit_log")
}

// ==========================================
// ADMIN & SUPPORT OPS
// ==========================================

model AdminAuditLog {
  id            String   @id @default(cuid())
  actorUserId   String   @map("actor_user_id")
  action        String
  targetUserId  String?  @map("target_user_id")
  timestamp     DateTime @default(now())
  metadata      Json?
  
  // Relations
  actorUser     User     @relation("AdminAuditLogActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser    User?    @relation("AdminAuditLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  
  // Indexes
  @@index([actorUserId, timestamp(sort: Desc)])
  @@index([targetUserId, timestamp(sort: Desc)])
  @@index([action, timestamp(sort: Desc)])
  @@map("admin_audit_log")
}

model ImpersonationSession {
  id                String   @id @default(cuid())
  actorUserId       String   @map("actor_user_id")
  targetUserId      String   @map("target_user_id")
  startedAt         DateTime @default(now()) @map("started_at")
  endedAt           DateTime? @map("ended_at")
  reason            String
  impersonationToken String   @unique @map("impersonation_token")
  isActive          Boolean  @default(true) @map("is_active")
  
  // Relations
  actorUser         User     @relation("ActorImpersonation", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser        User     @relation("TargetImpersonation", fields: [targetUserId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([actorUserId])
  @@index([targetUserId])
  @@index([impersonationToken])
  @@index([isActive, startedAt(sort: Desc)])
  @@map("impersonation_sessions")
}

model SupportNote {
  id          String   @id @default(cuid())
  actorUserId String   @map("actor_user_id")
  targetUserId String  @map("target_user_id")
  note        String   @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  isInternal  Boolean  @default(true) @map("is_internal")
  
  // Relations
  actorUser   User     @relation("ActorSupportNotes", fields: [actorUserId], references: [id], onDelete: Cascade)
  targetUser  User     @relation("TargetSupportNotes", fields: [targetUserId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([targetUserId, createdAt(sort: Desc)])
  @@index([actorUserId, createdAt(sort: Desc)])
  @@map("support_notes")
}

model BroadcastJob {
  id              String   @id @default(cuid())
  subject         String
  htmlContent     String   @map("html_content") @db.Text
  textContent     String?  @map("text_content") @db.Text
  audienceFilter  Json     @map("audience_filter")
  status          String   @default("pending") // pending, processing, completed, failed
  createdBy       String   @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  totalRecipients Int?     @map("total_recipients")
  sentCount       Int      @default(0) @map("sent_count")
  failedCount     Int      @default(0) @map("failed_count")
  errorMessage    String?  @map("error_message") @db.Text
  metadata        Json?
  
  // Relations
  creator         User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  recipients      BroadcastRecipient[]
  
  // Indexes
  @@index([status, createdAt(sort: Desc)])
  @@index([createdBy, createdAt(sort: Desc)])
  @@map("broadcast_jobs")
}

model BroadcastRecipient {
  id          String   @id @default(cuid())
  jobId       String   @map("job_id")
  userId      String   @map("user_id")
  email       String
  status      String   @default("pending") // pending, sent, failed, skipped
  sentAt      DateTime? @map("sent_at")
  errorMessage String?  @map("error_message") @db.Text
  retryCount  Int      @default(0) @map("retry_count")
  
  // Relations
  job         BroadcastJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Indexes
  @@index([jobId, status])
  @@index([userId])
  @@map("broadcast_recipients")
}

// ==========================================
// RBAC (Role-Based Access Control)
// ==========================================

model RolePermission {
  id            String   @id @default(cuid())
  role          String   // owner, admin, dev, viewer, compliance-auditor
  permission    String   // manage_team, view_audit, export_reports, run_autopilot, etc.
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@unique([role, permission])
  @@index([role])
  @@index([permission])
  @@map("role_permissions")
}

model TeamInvitation {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  email           String
  role            String   @default("viewer") // owner, admin, dev, viewer, compliance-auditor
  invitedBy       String   @map("invited_by")
  token           String   @unique
  status          String   @default("pending") // pending, accepted, expired, revoked
  expiresAt       DateTime @map("expires_at")
  acceptedAt      DateTime? @map("accepted_at")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([organizationId])
  @@index([email])
  @@index([token])
  @@index([status])
  @@map("team_invitations")
}

model RBACActivityLog {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  actorUserId     String   @map("actor_user_id")
  targetUserId    String?  @map("target_user_id")
  action          String   // role_assigned, role_changed, member_invited, member_removed, permission_checked
  previousRole    String?  @map("previous_role")
  newRole         String?  @map("new_role")
  permission      String?  // Permission that was checked/denied
  allowed         Boolean? // Whether the action was allowed
  metadata        Json?
  ipAddress       String?  @map("ip_address")
  userAgent       String?  @map("user_agent")
  
  // Timestamps
  timestamp       DateTime @default(now())
  
  @@index([organizationId, timestamp])
  @@index([actorUserId, timestamp])
  @@index([targetUserId, timestamp])
  @@index([action, timestamp])
  @@map("rbac_activity_log")
}

// ==========================================
// FEATURE FLAGS
// ==========================================

model FeatureFlag {
  id              String   @id @default(cuid())
  key             String   @unique
  enabled         Boolean  @default(false)
  rolloutPercent  Int      @default(0) // 0-100
  allowedUserIds   String[] // Array of specific user IDs
  description     String?
  metadata        Json?    // Additional flag data
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([key])
  @@index([enabled])
  @@map("feature_flags")
}

model Feedback {
  id              String   @id @default(cuid())
  userId          String?  // Optional - allow anonymous feedback
  category        String   // bug, feature, ui, performance, other
  severity        String   // low, medium, high, critical
  message         String   @db.Text
  email           String?  // User email for follow-up
  route           String?  // Current route when submitted
  includeDiagnostics Boolean @default(false)
  
  // Diagnostics bundle (JSON)
  diagnostics     Json?    // Browser info, errors, network status
  
  // Status tracking
  status          String   @default("new") // new, in_progress, resolved, closed
  assignedTo      String?
  adminResponse   String?  @db.Text
  resolvedAt      DateTime?
  resolvedBy      String?
  
  // Relations
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@map("feedback")
}

model IncidentMessage {
  id              String   @id @default(cuid())
  status          String   @default("active") // active, resolved
  message         String   @db.Text
  severity        String   // info, warning, error, critical
  createdBy       String   // Admin user ID who created it
  
  // Relations
  creator         User     @relation("IncidentCreator", fields: [createdBy], references: [id])
  
  // Timestamps
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?

  @@index([status])
  @@index([severity])
  @@index([createdBy])  // Added: Admin incident lookups
  @@map("incident_messages")
}

// ==========================================
// USER PREFERENCES
// ==========================================

model UserPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique @map("user_id")
  
  // Notification preferences
  emailNotifications    Boolean  @default(true) @map("email_notifications")
  inAppNotifications    Boolean  @default(true) @map("in_app_notifications")
  slackWebhook          String?  @map("slack_webhook")
  weeklyDigest          Boolean  @default(true) @map("weekly_digest")
  securityAlerts        Boolean  @default(true) @map("security_alerts")
  scanComplete          Boolean  @default(true) @map("scan_complete")
  teamInvites           Boolean  @default(true) @map("team_invites")
  
  // Scan preferences
  scanDepth             String   @default("standard") @map("scan_depth") // quick, standard, deep
  autoScan              Boolean  @default(false) @map("auto_scan")
  ignoredPaths          String?  @map("ignored_paths") @db.Text
  severityThreshold     String   @default("medium") @map("severity_threshold") // low, medium, high, critical
  parallelScans         Boolean  @default(true) @map("parallel_scans")
  timeoutMinutes        Int      @default(30) @map("timeout_minutes")
  
  // Appearance preferences
  theme                 String   @default("dark") // dark, light, system
  compactMode           Boolean  @default(false) @map("compact_mode")
  sidebarCollapsed      Boolean  @default(false) @map("sidebar_collapsed")
  codeSyntaxHighlighting Boolean @default(true) @map("code_syntax_highlighting")
  animationsEnabled     Boolean  @default(true) @map("animations_enabled")
  
  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@map("user_preferences")
}

// ==========================================
// WEBHOOK SUBSCRIPTIONS & DELIVERIES
// ==========================================

model WebhookSubscription {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  url             String
  events          String[] // Array of event types to subscribe to
  secret          String?  // HMAC secret for signature verification
  isActive        Boolean  @default(true) @map("is_active")
  timeout         Int      @default(10000) // milliseconds
  retryConfig     Json?    @map("retry_config") // Retry configuration
  headers         Json?    // Custom headers
  rateLimit       Json?    @map("rate_limit") // Rate limit config
  lastDeliveryAt  DateTime? @map("last_delivery_at")
  failureCount    Int      @default(0) @map("failure_count")
  metadata        Json?
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries      WebhookDelivery[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([userId])
  @@index([isActive])
  @@map("webhook_subscriptions")
}

model WebhookEvent {
  id              String   @id @default(cuid())
  type            String   // scan.completed, scan.failed, etc.
  data            Json     // Event payload
  source          String   @default("system") // system, user, integration
  version         String   @default("1.0")
  signature       String?
  metadata        Json?
  
  deliveries      WebhookDelivery[]
  
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@index([type, createdAt])
  @@map("webhook_events")
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  subscriptionId  String   @map("subscription_id")
  eventId         String   @map("event_id")
  attempt         Int      @default(1)
  status          String   // pending, delivered, failed
  statusCode      Int?     @map("status_code")
  responseTime    Int?     @map("response_time") // milliseconds
  error           String?
  responseBody     String?  @db.Text @map("response_body")
  retryAt         DateTime? @map("retry_at")
  
  subscription    WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event           WebhookEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now()) @map("created_at")
  deliveredAt     DateTime? @map("delivered_at")
  
  @@index([subscriptionId, status])
  @@index([eventId])
  @@index([retryAt])
  @@map("webhook_deliveries")
}

// ==========================================
// NEW MODELS FOR ENHANCEMENTS
// ==========================================

model ScheduledScan {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  repositoryId    String?  @map("repository_id")
  schedule        String   // cron expression
  enabled         Boolean  @default(true)
  lastRun         DateTime? @map("last_run")
  nextRun         DateTime? @map("next_run")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([nextRun])
  @@map("scheduled_scans")
}

model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String   // email, slack, webhook
  enabled     Boolean  @default(true)
  events      String[] // critical_finding, scan_complete, scheduled_scan
  config      Json     // Slack webhook URL, email address, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}
