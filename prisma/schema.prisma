// Prisma Schema for GUARDRAIL AI
// Database schema for subscriptions, users, payments, and usage tracking
//
// Canonical schema + migrations live here (prisma/migrations/). The @guardrail/database
// package mirrors this file under packages/database/prisma/ for package-local tooling.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS & AUTHENTICATION
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?   // Nullable for OAuth users
  avatar        String?
  emailVerified DateTime?
  role          String    @default("user") // user, admin, support
  
  // OAuth provider info
  provider      String?   // github, google, internal, etc.
  providerId    String?   @map("provider_id")
  
  // Stripe
  stripeCustomerId String? @unique
  
  // Age verification
  isAgeConfirmed Boolean @default(false) @map("is_age_confirmed")
  ageConfirmedAt DateTime? @map("age_confirmed_at")
  
  // Multi-Factor Authentication (MFA)
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") // Encrypted TOTP secret
  mfaBackupCodes String[]  @default([]) @map("mfa_backup_codes") // Encrypted backup codes
  mfaVerifiedAt  DateTime? @map("mfa_verified_at")
  
  // Relations
  subscriptions Subscription[]
  projects      Project[]
  teamMembers   TeamMember[]
  apiKeys       ApiKey[]
  usageRecords  UsageRecord[]
  licenseKeys   LicenseKey[]
  invoices      Invoice[]
  usageLogs     UsageLog[]
  teamSeats     TeamSeat[] @relation("TeamSeatUser")
  organizationMembers OrganizationMember[] @relation("OrganizationMemberUser")
  githubAccount GithubAccount?
  repositories  Repository[] @relation("UserRepositories")
  refreshTokens RefreshToken[]
  usageCounters UsageCounter[]
  usageTokens   UsageToken[]
  onboarding    UserOnboarding?
  scans         Scan[]
  reports       Report[]
  preferences   UserPreferences?
  webhookSubscriptions WebhookSubscription[]
  
  // Ops & UX relations
  feedback      Feedback[]
  
  // Compliance relations
  consentPreferences ConsentPreferences[]
  legalAcceptances LegalAcceptance[]
  gdprJobs       GdprJob[]
  gdprAuditLogs  GdprAuditLog[]
  
  // Admin & Support Ops relations
  adminAuditLogsActor AdminAuditLog[] @relation("AdminAuditLogActor")
  adminAuditLogsTarget AdminAuditLog[] @relation("AdminAuditLogTarget")
  actorImpersonation ImpersonationSession[] @relation("ActorImpersonation")
  targetImpersonation ImpersonationSession[] @relation("TargetImpersonation")
  actorSupportNotes SupportNote[] @relation("ActorSupportNotes")
  targetSupportNotes SupportNote[] @relation("TargetSupportNotes")
  broadcastJobs BroadcastJob[]
  incidentMessages IncidentMessage[] @relation("IncidentCreator")
  
  // New Relations
  notificationPreferences NotificationPreference[]
  scheduledScans          ScheduledScan[]

  // Timestamps
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

// ==========================================
// TOKEN BLACKLIST (for logout invalidation)
// ==========================================

model TokenBlacklist {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([expiresAt])
  @@map("token_blacklist")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  token       String   @unique
  expiresAt   DateTime @map("expires_at")
  revoked     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model OAuthState {
  id        Int      @id @default(autoincrement())
  state     String   @unique
  provider  String   @default("github")
  sessionId String?  @map("session_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("oauth_states")
}

// ==========================================
// SUBSCRIPTIONS & PAYMENTS
// ==========================================

model Subscription {
  id                String   @id @default(cuid())
  userId            String
  stripeSubscriptionId String? @unique
  stripeCustomerId String
  tier              String   // free, pro, team, enterprise
  status            String   // active, canceled, past_due, trialing, incomplete
  priceId           String?
  quantity          Int      @default(1) // For seat-based pricing
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  trialEnd          DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  metadata          Json?
  
  // Relations
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  payments          Payment[]
  invoices          Invoice[]
  teamSeats         TeamSeat[]
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])  // Added: User subscription lookups
  @@index([status])  // Added: Subscription status filtering
  @@index([tier])    // Added: Tier-based queries
  @@map("subscriptions")
}

model Payment {
  id              String   @id @default(cuid())
  subscriptionId  String
  stripePaymentIntentId String? @unique
  amount          Int      // in cents
  currency        String   @default("usd")
  status          String   // succeeded, pending, failed
  description      String?
  
  // Relations
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([subscriptionId])  // Added: Subscription payment history
  @@index([status])          // Added: Payment status filtering
  @@index([createdAt])       // Added: Payment date sorting
  @@map("payments")
}

// ==========================================
// PROJECTS & TEAMS
// ==========================================

model Project {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String?
  path            String?  // Local file path
  repositoryUrl   String?
  
  // Metrics
  fileCount       Int      @default(0)
  lineCount       Int      @default(0)
  sizeBytes       BigInt   @default(0)
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamMembers     TeamMember[]
  usageRecords    UsageRecord[]
  
  // Compliance relations
  complianceAssessments ComplianceAssessment[]
  complianceSchedules ComplianceSchedule[]
  complianceReports ComplianceReport[]
  alerts           Alert[]
  alertConfigs     AlertConfig[]
  remediationTasks RemediationTask[]
  reportSchedules  ReportSchedule[]
  evidenceCollections EvidenceCollection[]
  kubernetesScans   KubernetesScan[]
  containerScans    ContainerScan[]
  iaCScans          IaCScan[]
  piiDetections     PIIDetection[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])     // Added: User project listings
  @@index([createdAt])  // Added: Project date sorting
  @@map("projects")
}

model Team {
  id              String   @id @default(cuid())
  name            String
  subscriptionId String?  // Team subscription
  
  // Relations
  members         TeamMember[]
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([subscriptionId])  // Added: Team billing lookups
  @@map("teams")
}

model TeamMember {
  id              String   @id @default(cuid())
  teamId          String
  userId          String
  role            String   @default("member") // owner, admin, member
  
  // Relations
  team            Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId       String?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([teamId])     // Added: Team membership queries
  @@index([userId])     // Added: User team memberships
  @@index([projectId])  // Added: Project member lookups
  @@map("team_members")
}

// ==========================================
// USAGE TRACKING
// ==========================================

model UsageRecord {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  type            String   // validation, api_call, embedding, etc.
  count           Int      @default(1)
  metadata        Json?    // Additional data
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  
  // Timestamps
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@map("usage_records")
}

// ==========================================
// API KEYS
// ==========================================

model ApiKey {
  id              String   @id @default(cuid())
  userId          String
  name            String
  key             String   @unique  // Stores SHA-256 hash of the key (NOT the raw key)
  prefix          String?  // First 8-12 chars of key for display (e.g., "grl_abc123...")
  tierOverride    String?  // Optional tier override (free, starter, pro, compliance, enterprise)
  lastUsedAt      DateTime?
  expiresAt       DateTime?
  revokedAt       DateTime? // Soft delete - when key was revoked
  isActive        Boolean  @default(true)
  scopes          String[] @default(["read"]) // Permission scopes
  
  // Security policy fields
  allowedIpCidrs  String[] // IP CIDR ranges that can use this key
  allowedCountries String[] // Country codes (ISO 3166-1 alpha-2)
  allowedHoursUtc Json?    // { start: number, end: number } - UTC hours when key is valid
  sensitiveScopes String[] @default([]) // Scopes requiring stricter checks
  fingerprintHash String? // Hash of (IP + User-Agent) for fingerprinting
  lastFingerprint  String? // Last fingerprint seen (for change detection)
  requestsPerDay  Int      @default(-1) // -1 for unlimited
  expensivePerDay Int      @default(-1) // -1 for unlimited
  currentDayRequests Int @default(0) // Counter for today
  currentDayExpensive Int @default(0) // Counter for expensive ops today
  lastDayReset     DateTime @default(now()) // When daily counters were last reset
  
  // Key rotation support
  rotatedFromId   String?  // ID of key this was rotated from
  rotationOverlapDays Int @default(0) // Overlap window in days
  
  // Relations
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rotatedFrom     ApiKey?  @relation("ApiKeyRotations", fields: [rotatedFromId], references: [id])
  rotatedKeys     ApiKey[] @relation("ApiKeyRotations")
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([key])  // Index on hash for fast lookup
  @@index([userId])
  @@index([rotatedFromId])
  @@map("api_keys")
}

// ==========================================
// ANALYTICS
// ==========================================

model Analytics {
  id              String   @id @default(cuid())
  userId          String?
  projectId       String?
  event           String
  properties      Json?
  
  // Timestamps
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@map("analytics")
}

// ==========================================
// CODE EVOLUTION
// ==========================================

model CodeSnapshot {
  id              String   @id @default(cuid())
  projectId       String
  timestamp       DateTime @default(now())
  patterns        Json     // Array of pattern objects
  metrics         Json     // Metrics object
  fileHashes      Json     // Record of file hashes
  changes         Json     // Changes since last snapshot
  metadata        Json?
  
  @@index([projectId, timestamp])
  @@map("code_snapshots")
}

model EvolutionTrend {
  id              String   @id @default(cuid())
  projectId       String
  pattern         String
  trend           String   // increasing, decreasing, stable, emerging, declining
  change          Float
  changePercent   Float
  dataPoints      Json     // Array of {timestamp, value}
  prediction      Json     // Prediction object
  updatedAt       DateTime @updatedAt
  
  @@unique([projectId, pattern])
  @@index([projectId])
  @@map("evolution_trends")
}

// ==========================================
// COLLABORATION ROOMS
// ==========================================

model CollaborationRoom {
  id              String   @id @default(cuid())
  name            String
  projectId       String?
  createdById     String
  isPublic        Boolean  @default(false)
  maxMembers      Int      @default(10)
  settings        Json?
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([projectId])
  @@index([createdById])  // Added: Room creator lookups
  @@map("collaboration_rooms")
}

model RoomActivity {
  id              String   @id @default(cuid())
  roomId          String
  userId          String
  userName        String
  type            String   // edit, comment, join, leave
  message         String
  file            String?
  data            Json?
  
  // Timestamps
  createdAt       DateTime @default(now())

  @@index([roomId, createdAt])
  @@index([userId])  // Added: User activity lookups
  @@map("room_activities")
}

// ==========================================
// CROSS-REPO INTELLIGENCE
// ==========================================

model RepositoryAnalysis {
  id              String   @id @default(cuid())
  owner           String
  repo            String
  fullName        String
  language        String?
  stars           Int      @default(0)
  forks           Int      @default(0)
  patterns        Json     // Detected patterns
  contributors    Json     // Top contributors
  analyzedAt      DateTime @default(now())
  
  @@unique([owner, repo])
  @@index([fullName])
  @@map("repository_analyses")
}

model CrossRepoInsight {
  id              String   @id @default(cuid())
  category        String   // Authentication, Error Handling, etc.
  bestRepo        String
  reason          String
  confidence      Float
  recommendation  String
  codeSnippet     String?  @db.Text
  repos           Json     // Array of repo names involved
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([category])
  @@map("cross_repo_insights")
}

// ==========================================
// DESIGN SYSTEM
// ==========================================

model DesignSystem {
  id              String   @id @default(cuid())
  projectId       String
  name            String
  isLocked        Boolean  @default(false)
  tokens          Json     // All design tokens
  components      Json     // Extracted components
  patterns        Json     // Detected patterns
  statistics      Json     // Analysis statistics
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([projectId])
  @@map("design_systems")
}

// ==========================================
// COMPLIANCE & AUDIT
// ==========================================

model ComplianceAssessment {
  id          String   @id @default(cuid())
  projectId   String
  frameworkId String
  summary     Json     // Assessment summary with scores
  evidence    Json?    // Evidence collected
  controls    Json     // Control assessments
  gaps        Json?    // Identified gaps
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId, frameworkId])
  @@map("compliance_assessments")
}

model AuditEvent {
  id            String   @id @default(cuid())
  type          String
  category      String
  projectId     String?
  frameworkId   String?
  timestamp     DateTime @default(now())
  severity      String
  source        String
  userId        String?
  metadata      Json?
  details       Json?
  
  // Audit trail fields
  sequenceNumber BigInt?
  hash          String?
  previousHash  String?
  
  // Timestamps
  createdAt     DateTime @default(now())
  
  @@index([projectId, timestamp])
  @@index([type, timestamp])
  @@index([userId])  // Added: User audit trail lookups
  @@map("audit_events")
}

model ComplianceSchedule {
  id            String   @id @default(cuid())
  projectId     String
  frameworkId   String
  schedule      String   // Cron expression
  enabled       Boolean  @default(true)
  lastRun       DateTime?
  nextRun       DateTime?
  notifications Json?    // Notification settings
  
  // Relations
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  evidenceCollections EvidenceCollection[]
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([projectId, frameworkId])
  @@map("compliance_schedules")
}

model Alert {
  id            String   @id @default(cuid())
  projectId     String
  type          String   // violation, deadline, score_drop, system
  severity      String   // low, medium, high, critical
  message       String
  acknowledged  Boolean  @default(false)
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolved      Boolean  @default(false)
  resolvedBy    String?
  resolvedAt    DateTime?
  
  // Relations
  project       Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([projectId, resolved])
  @@index([severity])
  @@map("alerts")
}

model AlertConfig {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // score_threshold, violation_detected, deadline_approaching, system_error
  enabled     Boolean  @default(true)
  threshold   Int?     // For score thresholds
  recipients  Json     // Email, Slack, webhook settings
  conditions  Json     // Alert conditions
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([projectId, type])
  @@map("alert_configs")
}

model RemediationTask {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      String   @default("pending") // pending, in_progress, completed, cancelled
  priority    String   // low, medium, high, critical
  assignedTo  String?
  dueDate     DateTime?
  completedAt DateTime?
  metadata    Json?    // Additional task data
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId, status])
  @@index([dueDate])
  @@index([assignedTo])  // Added: Assignee task lookups
  @@map("remediation_tasks")
}

model ReportSchedule {
  id          String   @id @default(cuid())
  projectId   String
  frameworkId String?
  frequency   String   // daily, weekly, monthly, quarterly
  format      String   // pdf, html, json
  recipients  Json     // Who receives the report
  lastRun     DateTime?
  nextRun     DateTime
  enabled     Boolean  @default(true)
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId, nextRun])
  @@map("report_schedules")
}

model EvidenceCollection {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String?
  artifacts   Json     // Array of evidence artifacts
  metadata    Json?    // Framework ID, assessment ID, etc.
  complianceScheduleId String?
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  complianceSchedule ComplianceSchedule? @relation(fields: [complianceScheduleId], references: [id])
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])             // Added: Project evidence lookups
  @@index([complianceScheduleId])  // Added: Schedule evidence lookups
  @@map("evidence_collections")
}

// Additional models for compliance tracking
model KubernetesScan {
  id          String   @id @default(cuid())
  projectId   String
  clusterName String
  scanDate    DateTime @default(now())
  results     Json     // Scan results
  status      String   // 'passed' | 'failed' | 'warning'
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])  // Added: Project K8s scan lookups
  @@index([status])     // Added: Scan status filtering
  @@map("kubernetes_scans")
}

model ContainerScan {
  id          String   @id @default(cuid())
  projectId   String
  imageId     String
  imageTag    String
  scanDate    DateTime @default(now())
  results     Json     // Scan results
  status      String   // 'passed' | 'failed' | 'warning'
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])  // Added: Project container scan lookups
  @@index([status])     // Added: Scan status filtering
  @@map("container_scans")
}

model IaCScan {
  id          String   @id @default(cuid())
  projectId   String
  templatePath String
  scanDate    DateTime @default(now())
  results     Json     // Scan results
  status      String   // 'passed' | 'failed' | 'warning'
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])  // Added: Project IaC scan lookups
  @@index([status])     // Added: Scan status filtering
  @@map("iac_scans")
}

model PIIDetection {
  id          String   @id @default(cuid())
  projectId   String
  filePath    String
  scanDate    DateTime @default(now())
  findings    Json     // PII findings
  confidence  Float    // Confidence score
  status      String   // 'passed' | 'failed' | 'warning'
  
  // Relations
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([projectId])  // Added: Project PII scan lookups
  @@index([status])     // Added: Scan status filtering
  @@map("pii_detections")
}

model ComplianceReport {
  id                String   @id @default(cuid())
  projectId         String
  frameworkId       String
  type              String   // 'compliance' | 'audit' | 'executive' | 'technical' | 'remediation'
  format            String   // 'pdf' | 'html' | 'json' | 'csv'
  generatedAt       DateTime @default(now())
  periodStart       DateTime?
  periodEnd         DateTime?
  summary           Json     // Compliance summary
  evidence          Json?    // Evidence data
  controls          Json     // Control assessments
  gaps              Json?    // Compliance gaps
  status            String   @default("draft") // 'draft' | 'reviewing' | 'approved' | 'archived'
  
  // Relations
  project           Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@index([projectId])     // Added: Project compliance report lookups
  @@index([frameworkId])   // Added: Framework report lookups
  @@index([status])        // Added: Report status filtering
  @@index([generatedAt])   // Added: Report date sorting
  @@map("compliance_reports")
}

// ==========================================
// MULTI-TENANCY
// ==========================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  domain    String
  status    String   @default("active") // active, inactive, suspended
  plan      String   @default("free") // free, pro, enterprise
  settings  Json     @default("{}")
  limits    Json     @default("{}")
  usage     Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  tenantUsers TenantUser[]

  @@index([domain])
  @@map("tenants")
}

model TenantUser {
  tenantId String   @map("tenant_id")
  userId   String   @map("user_id")
  role     String   @default("member") // owner, admin, member, viewer
  joinedAt DateTime @default(now()) @map("joined_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
  @@map("tenant_users")
}

// ==========================================
// GITHUB INTEGRATION
// ==========================================

model GithubAccount {
  id            String   @id @default(cuid())
  userId        String
  githubId      String
  username      String
  accessToken   String
  refreshToken  String?
  scope         String?
  tokenType     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  repositories  Repository[] @relation("GithubRepositories")
  
  @@unique([userId])
  @@map("github_accounts")
}

// GitHub App Installation - tracks installed GitHub Apps
model GitHubAppInstallation {
  id              String   @id @default(cuid())
  installationId  BigInt   @unique @map("installation_id")  // GitHub's installation ID
  accountId       BigInt   @map("account_id")               // GitHub account (org or user) ID
  accountLogin    String   @map("account_login")            // GitHub account login name
  accountType     String   @map("account_type")             // "Organization" or "User"
  targetType      String   @default("Organization") @map("target_type")
  
  // Repository selection
  repositorySelection String @default("all") @map("repository_selection") // "all" or "selected"
  
  // Permissions and events
  permissions     Json?                                      // Permissions granted
  events          String[] @default([])                      // Webhook events subscribed
  
  // Status tracking
  isActive        Boolean  @default(true) @map("is_active")
  suspendedAt     DateTime? @map("suspended_at")
  suspendedBy     String?   @map("suspended_by")
  
  // User association (optional - if installed by a known user)
  userId          String?  @map("user_id")
  
  // Last webhook received
  lastWebhookAt   DateTime? @map("last_webhook_at")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  installedRepos  GitHubAppRepository[]
  webhookEvents   GitHubWebhookEvent[]
  checkRuns       GitHubCheckRun[]
  
  @@index([accountLogin])
  @@index([userId])
  @@index([isActive])
  @@map("github_app_installations")
}

// GitHub App Repository - tracks which repos are included in an installation
model GitHubAppRepository {
  id              String   @id @default(cuid())
  installationId  String   @map("installation_id")
  repositoryId    BigInt   @map("repository_id")           // GitHub's repository ID
  fullName        String   @map("full_name")               // owner/repo format
  name            String
  isPrivate       Boolean  @default(false) @map("is_private")
  defaultBranch   String   @default("main") @map("default_branch")
  
  // Scan configuration
  autoScanEnabled Boolean  @default(true) @map("auto_scan_enabled")
  lastScanAt      DateTime? @map("last_scan_at")
  
  // Status
  isActive        Boolean  @default(true) @map("is_active")
  
  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  installation    GitHubAppInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  webhookEvents   GitHubWebhookEvent[]
  checkRuns       GitHubCheckRun[]
  
  @@unique([installationId, repositoryId])
  @@index([fullName])
  @@index([repositoryId])
  @@map("github_app_repositories")
}

// GitHub Webhook Event - for idempotency tracking
model GitHubWebhookEvent {
  id              String   @id @default(cuid())
  deliveryId      String   @unique @map("delivery_id")     // x-github-delivery header
  eventType       String   @map("event_type")              // push, pull_request, etc.
  action          String?                                   // opened, synchronize, etc.
  
  // Repository info
  installationId  String?  @map("installation_id")
  repositoryId    String?  @map("repository_id")
  
  // Commit/PR info for idempotency
  sha             String?                                   // Commit SHA
  prNumber        Int?     @map("pr_number")
  ref             String?                                   // Branch ref
  
  // Processing status
  status          String   @default("received")             // received, processing, completed, failed, skipped
  processedAt     DateTime? @map("processed_at")
  error           String?
  
  // Idempotency: track if we already processed this SHA for checks/comments
  checkRunCreated Boolean  @default(false) @map("check_run_created")
  commentPosted   Boolean  @default(false) @map("comment_posted")
  
  // Associated run/scan
  runId           String?  @map("run_id")
  
  // Raw payload (for debugging)
  payloadHash     String?  @map("payload_hash")            // Hash of payload for duplicate detection
  
  // Timestamps
  receivedAt      DateTime @default(now()) @map("received_at")
  createdAt       DateTime @default(now()) @map("created_at")
  
  // Relations
  installation    GitHubAppInstallation? @relation(fields: [installationId], references: [id], onDelete: SetNull)
  repository      GitHubAppRepository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)
  
  @@index([sha, eventType])
  @@index([prNumber])
  @@index([status])
  @@index([receivedAt])
  @@map("github_webhook_events")
}

// GitHub Check Run - tracks check runs created for commits
model GitHubCheckRun {
  id              String   @id @default(cuid())
  checkRunId      BigInt   @unique @map("check_run_id")    // GitHub's check run ID
  
  // Installation and repo
  installationId  String   @map("installation_id")
  repositoryId    String   @map("repository_id")
  
  // Check run details
  headSha         String   @map("head_sha")
  name            String   @default("Guardrail Security Scan")
  status          String   @default("queued")              // queued, in_progress, completed
  conclusion      String?                                   // success, failure, neutral, etc.
  
  // PR association (if from PR)
  prNumber        Int?     @map("pr_number")
  
  // Associated run
  runId           String?  @map("run_id")
  
  // Summary info
  title           String?
  summary         String?  @db.Text
  annotationsCount Int     @default(0) @map("annotations_count")
  
  // Timestamps
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  installation    GitHubAppInstallation @relation(fields: [installationId], references: [id], onDelete: Cascade)
  repository      GitHubAppRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  
  @@index([headSha])
  @@index([prNumber])
  @@index([status])
  @@index([runId])
  @@map("github_check_runs")
}

model Repository {
  id            String   @id @default(cuid())
  githubId      String   @unique
  userId        String
  name          String
  fullName      String
  description   String?
  isPrivate     Boolean  @default(false)
