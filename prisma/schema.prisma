// ==========================================
// CODE SCANS & FINDINGS
// ==========================================

model Scan {
  id            String    @id @default(cuid()) @map("id")
  userId        String    @map("user_id")
  repositoryId  String?   @map("repository_id")
  projectPath   String?   @map("project_path") // Local path or repo full name
  branch        String    @default("main")
  commitSha     String?   @map("commit_sha")
  
  // Status tracking
  status        String    @default("queued") // queued, running, completed, failed
  progress      Int       @default(0) // 0-100
  
  // Results summary
  verdict       String?   // pass, fail, review
  score         Int?      // 0-100 overall score
  
  // Metrics
  filesScanned  Int       @default(0) @map("files_scanned")
  linesScanned  Int       @default(0) @map("lines_scanned")
  issuesFound   Int       @default(0) @map("issues_found")
  criticalCount Int       @default(0) @map("critical_count")
  warningCount  Int       @default(0) @map("warning_count")
  infoCount     Int       @default(0) @map("info_count")
  
  // Timing
  startedAt     DateTime? @map("started_at")
  completedAt   DateTime? @map("completed_at")
  durationMs    Int?      @map("duration_ms")
  
  // Error handling
  error         String?
  
  // Retry logic
  retryCount    Int      @default(0) @map("retry_count")
  lastRetryAt   DateTime? @map("last_retry_at")
  maxRetries    Int      @default(3) @map("max_retries")
  
  // Relations
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  findings      Finding[]
  
  // Timestamps
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  @@index([userId, createdAt])
  @@index([repositoryId])
  @@index([status])
  @@index([retryCount, status])
  @@map("scans")
}

model Finding {
  id            String   @id @default(cuid())
  scanId        String   @map("scan_id")
  
  // Classification
  type          String   // fake_feature, unused_export, empty_function, console_only, 
                         // hardcoded_return, todo_without_impl, mock_data, dead_endpoint,
                         // unreachable_code, stub_implementation
  severity      String   // critical, warning, info
  category      String   // fake_feature, code_quality, security, best_practice
  
  // Location
  file          String
  line          Int
  column        Int?     @map("column")
  endLine       Int?     @map("end_line")
  endColumn     Int?     @map("end_column")
  
  // Content
  title         String
  message       String
  codeSnippet   String?  @map("code_snippet") @db.Text
  suggestion    String?  @db.Text
  
  // AI Analysis
  confidence    Float    @default(0.8) // 0.0-1.0
  aiExplanation String?  @map("ai_explanation") @db.Text
  aiGenerated   Boolean  @default(false) @map("ai_generated")
  
  // Status
  status        String   @default("open") // open, acknowledged, fixed, false_positive, suppressed, accepted_risk
  
  // Deduplication
  occurrenceCount Int    @default(1) @map("occurrence_count")
  firstSeenAt     DateTime @default(now()) @map("first_seen_at")
  lastSeenAt      DateTime @default(now()) @map("last_seen_at")
  deduplicationKey String? @map("deduplication_key")
  
  // Metadata
  ruleId        String?  @map("rule_id")
  metadata      Json?
  
  // Relations
  scan          Scan     @relation(fields: [scanId], references: [id], onDelete: Cascade)
  
  // Timestamps
  createdAt     DateTime @default(now()) @map("created_at")
  
  @@index([scanId])
  @@index([type])
  @@index([severity])
  @@index([file])
  @@index([deduplicationKey])
  @@index([firstSeenAt])
  @@map("findings")
}

