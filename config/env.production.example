# =============================================================================
# RAILGUARD Production Environment Variables
# =============================================================================
# Railway Project: RailGuard
# Domain: getguardrail.io
# API: api.getguardrail.io
# Web UI: app.getguardrail.io (or www.getguardrail.io)
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Database (Railway PostgreSQL or external)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/railguard

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=<generate-secure-secret>
JWT_REFRESH_SECRET=<generate-secure-secret>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS - Allow your frontend domains
# -----------------------------------------------------------------------------
CORS_ORIGIN=https://getguardrail.io,https://www.getguardrail.io,https://app.getguardrail.io

# -----------------------------------------------------------------------------
# URLs
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://app.getguardrail.io
NEXT_PUBLIC_API_URL=https://api.getguardrail.io
API_BASE_URL=https://api.getguardrail.io
APP_BASE_URL=https://app.getguardrail.io

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
# Create OAuth App at: https://github.com/settings/developers
# Homepage URL: https://getguardrail.io
# Authorization callback URL: https://api.getguardrail.io/api/auth/github/callback
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>
GITHUB_CALLBACK_URL=https://api.getguardrail.io/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=<your-webhook-secret>

# -----------------------------------------------------------------------------
# Stripe (LIVE MODE for production)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_<your-live-key>
STRIPE_PUBLISHABLE_KEY=pk_live_<your-live-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-secret>
STRIPE_PRICE_ID_STARTER=price_<starter-price-id>
STRIPE_PRICE_ID_PRO=price_<pro-price-id>
STRIPE_PRICE_ID_ENTERPRISE=price_<enterprise-price-id>

# -----------------------------------------------------------------------------
# OpenAI (for AI features)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-<your-openai-key>

# -----------------------------------------------------------------------------
# Email (for notifications and digests)
# -----------------------------------------------------------------------------
EMAIL_FROM=noreply@getguardrail.io
SMTP_HOST=<your-smtp-host>
SMTP_PORT=587
SMTP_USER=<your-smtp-user>
SMTP_PASS=<your-smtp-password>

# -----------------------------------------------------------------------------
# Redis (for caching and rate limiting)
# -----------------------------------------------------------------------------
REDIS_URL=redis://<your-redis-url>

# -----------------------------------------------------------------------------
# Sentry Error Tracking
# -----------------------------------------------------------------------------
SENTRY_DSN=<your-sentry-dsn>
SENTRY_ORG=guardrail
SENTRY_PROJECT=railguard-api

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_METRICS=true
ENABLE_AI_FEATURES=true
GUARDRAIL_DEMO_MODE=false
GUARDRAIL_POLICY_STRICT=true

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Deploy Hooks (for Autopilot)
# -----------------------------------------------------------------------------
VERCEL_WEBHOOK_SECRET=<your-vercel-webhook-secret>
NETLIFY_WEBHOOK_SECRET=<your-netlify-webhook-secret>
RAILWAY_WEBHOOK_SECRET=<your-railway-webhook-secret>

# =============================================================================
# RAILWAY-SPECIFIC NOTES
# =============================================================================
# 1. Set these variables in Railway dashboard → Project → Variables
# 2. DATABASE_URL is auto-populated if you add Railway PostgreSQL
# 3. REDIS_URL is auto-populated if you add Railway Redis
# 4. Custom domain: Settings → Networking → Custom Domain → api.getguardrail.io
# =============================================================================
