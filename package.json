{
  "name": "@guardrail/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Guardrail - AI-native code security and guardrail platform",
  "packageManager": "pnpm@9.15.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "setup": "node bin/cli-wizard.js",
    "build": "turbo run build",
    "build:all": "turbo run build && pnpm run build:lib",
    "build:lib": "tsc -p tsconfig.lib.json",
    "build:cli-lib": "tsc -p tsconfig.cli-dist.json",
    "build:netlify": "pnpm install --frozen-lockfile --ignore-scripts && turbo run build --filter=@guardrail/web-ui",
    "deploy:production": "turbo run build && cd packages/cli && npm publish --access public",
    "dev": "turbo run dev --parallel",
    "test": "jest --config=config/jest.config.js",
    "test:watch": "jest --config=config/jest.config.js --watch",
    "test:coverage": "jest --config=config/jest.config.js --coverage",
    "test:unit": "jest --config=config/jest.config.js --selectProjects unit",
    "test:integration": "jest --config=config/jest.config.js --selectProjects integration",
    "test:db:setup": "scripts/setup-test-db.bat",
    "test:db:start": "docker-compose -f config/docker-compose.test.yml up -d",
    "test:db:stop": "docker-compose -f config/docker-compose.test.yml down",
    "test:websocket": "ts-node --esm scripts/test-websocket-collaboration.ts",
    "test:e2e": "playwright test --config=config/playwright.config.ts",
    "test:performance": "node scripts/run-performance-tests.js",
    "test:validate": "node scripts/validate-api-endpoints.js",
    "test:cli": "node scripts/test-cli.js",
    "test:load": "artillery run tests/performance/load-test.yml",
    "lint": "turbo run lint",
    "lint:root-src": "node scripts/check-no-new-root-src-ts.mjs",
    "lint:fix": "turbo run lint:fix",
    "clean": "turbo run clean",
    "type-check": "turbo run type-check",
    "db:generate": "turbo run db:generate --filter=@guardrail/database",
    "db:push": "turbo run db:push --filter=@guardrail/database",
    "db:migrate": "turbo run db:migrate --filter=@guardrail/database",
    "db:studio": "turbo run db:studio --filter=@guardrail/database",
    "db:migrate:prod": "chmod +x scripts/migrate-production.sh && ./scripts/migrate-production.sh",
    "env:copy": "chmod +x scripts/env-manager.sh && ./scripts/env-manager.sh copy",
    "env:check": "chmod +x scripts/env-manager.sh && ./scripts/env-manager.sh check",
    "api:dev": "turbo run dev --filter=@guardrail/api",
    "api:start": "turbo run start --filter=@guardrail/api",
    "api:build": "turbo run build --filter=@guardrail/api",
    "web:dev": "turbo run dev --filter=@guardrail/web-ui",
    "web:build": "turbo run build --filter=@guardrail/web-ui",
    "web:start": "turbo run start --filter=@guardrail/web-ui",
    "scan": "node bin/guardrail.js scan",
    "gate": "node bin/guardrail.js gate",
    "fix": "node bin/guardrail.js fix",
    "doctor": "node bin/guardrail.js doctor",
    "init": "node bin/guardrail.js init",
    "mcp": "node bin/guardrail.js mcp",
    "cli": "node bin/guardrail.js",
    "generate-mdc": "npx tsx scripts/generate-mdc.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@aws-sdk/client-auto-scaling": "^3.600.0",
    "@aws-sdk/client-cloudfront": "^3.600.0",
    "@aws-sdk/client-cloudwatch": "^3.600.0",
    "@aws-sdk/client-ec2": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@octokit/rest": "^20.0.0",
    "@sentry/nextjs": "^8.0.0",
    "@apidevtools/swagger-parser": "^10.1.0",
    "@lhci/cli": "0.12.0",
    "@playwright/test": "^1.57.0",
    "@prisma/client": "^5.22.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express-session": "^1.18.2",
    "@types/memoizee": "^0.4.12",
    "@types/passport": "^1.0.17",
    "@types/pg": "^8.16.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "bcrypt": "^5.1.1",
    "bcryptjs": "^2.4.3",
    "bundlesize": "^0.18.2",
    "commander": "^12.0.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.2",
    "ioredis": "^5.3.2",
    "jose": "^5.10.0",
    "memoizee": "^0.4.17",
    "openai": "^4.20.1",
    "openid-client": "^6.8.1",
    "passport": "^0.7.0",
    "pg": "^8.16.3",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "turbo": "^1.11.2",
    "typescript": "^5.3.3",
    "ws": "^8.18.3",
    "zod": "^3.25.76",
    "chokidar": "^3.6.0",
    "framer-motion": "^11.0.0",
    "@guardrail/core": "workspace:*",
    "guardrail-security": "workspace:*",
    "helmet": "^7.1.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@babel/core": "^7.28.5",
    "@babel/parser": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/traverse": "^7.28.5",
    "@babel/types": "^7.28.5",
    "@jest/globals": "^29.7.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/bcrypt": "^5.0.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/commander": "^2.12.2",
    "@types/cron": "^2.0.1",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.27",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "artillery": "^2.0.27",
    "babel-jest": "^30.2.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "lint-staged": "^16.2.7",
    "nock": "^14.0.10",
    "prettier": "^3.1.1",
    "stripe": "^17.0.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.6",
    "vitest": "^1.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "main": "bin/guardrail.js",
  "bin": {
    "guardrail": "bin/guardrail.js",
    "vc": "bin/guardrail.js"
  },
  "directories": {
    "doc": "docs",
    "example": "examples",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guardiavault-oss/codeguard.git"
  },
  "keywords": [
    "guardrail",
    "ai",
    "code-quality",
    "security",
    "ci-cd",
    "linting",
    "static-analysis",
    "devops",
    "developer-tools",
    "mcp",
    "ai-agents",
    "code-review"
  ],
  "author": "Guardrail Team <support@guardrail.dev> (https://guardrail.dev)",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/guardiavault-oss/codeguard/issues"
  },
  "homepage": "https://guardrail.dev",
  "pnpm": {
    "overrides": {
      "qs": ">=6.14.1",
      "esbuild": ">=0.25.0",
      "cookie": ">=0.7.0",
      "tmp": ">=0.2.4",
      "tar-fs": ">=2.1.3",
      "glob": "^7.2.3",
      "axios": ">=1.8.2",
      "ws": ">=8.17.1"
    }
  }
}
