# =============================================================================
# GUARDRAIL Environment Variables
# =============================================================================
# ⚠️  SECURITY WARNING: Never commit real secrets to version control!
# 
# Copy this file to .env and replace ALL placeholder values.
# Generate secrets with: openssl rand -base64 32
#
# REQUIRED (app will NOT start without these):
#   - DATABASE_URL
#   - JWT_SECRET (minimum 32 characters)
#
# OPTIONAL (features disabled if missing):
#   - GITHUB_CLIENT_ID/SECRET (GitHub OAuth)
#   - GOOGLE_CLIENT_ID/SECRET (Google OAuth)
#   - STRIPE_SECRET_KEY (billing features)
#   - OPENAI_API_KEY (AI features)
# =============================================================================

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local: docker run -d --name guardrail-db -p 5432:5432 -e POSTGRES_PASSWORD=localdev -e POSTGRES_DB=guardrail postgres:15
# Replace with your actual database URL - NEVER use production credentials here
DATABASE_URL=postgresql://postgres:REPLACE_WITH_PASSWORD@localhost:5432/guardrail

# -----------------------------------------------------------------------------
# Authentication Secrets
# -----------------------------------------------------------------------------
# ⚠️  CRITICAL: These secrets are pre-generated for production!
# Generate new ones with: openssl rand -base64 32
# Windows: [Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
#
# Minimum 32 characters required - app will fail to start if shorter
JWT_SECRET=mHk6m9eW5GP9dJpOh8Qt35xfh/9Qa3h15i307k+Q77o=
JWT_REFRESH_SECRET=3RV0DlIZ+1fa4dw/Gyx3c5HPQ6LMRSkGcmfeEaF2pbU=
COOKIE_SECRET=qU339XPJ0O535L5APh4JDe1++iHHjb9zEBV4yfoXV9o=
SESSION_SECRET=gCJ+WRmBq/fbKnXA762UA+kxLR57SvkDhqaFYG0AYrU=
CSRF_SECRET=XYNzfonMqIwwbEqg7oU+1FkxwHL9Mz7mdO7Q1d9nqSo=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Production CORS origins - update with your actual domains
CORS_ORIGIN=https://guardrail.network,https://app.guardrail.network,https://api.guardrail.network

# Allowed origin for web-ui Access-Control-Allow-Origin header
ALLOWED_ORIGIN=https://app.guardrail.network

# -----------------------------------------------------------------------------
# URLs (Production)
# -----------------------------------------------------------------------------
# API URL - deployed to Railway
NEXT_PUBLIC_API_URL=https://api.guardrail.network
API_BASE_URL=https://api.guardrail.network

# App URL - deployed to Netlify/Vercel
NEXT_PUBLIC_APP_URL=https://app.guardrail.network
APP_BASE_URL=https://app.guardrail.network

# WebSocket URL (required for real-time updates in production)
NEXT_PUBLIC_WS_URL=wss://api.guardrail.network/ws

# -----------------------------------------------------------------------------
# Redis (optional)
# -----------------------------------------------------------------------------
# docker run -d --name GUARDRAIL-redis -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AWS S3 (optional, for file uploads)
# -----------------------------------------------------------------------------
# Set FILE_STORAGE_PROVIDER=aws-s3 to enable S3 storage
# If not set, defaults to local storage
FILE_STORAGE_PROVIDER=local
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
UPLOAD_PATH=./uploads
UPLOAD_BASE_URL=http://localhost:3000/uploads

# -----------------------------------------------------------------------------
# Email (optional)
# -----------------------------------------------------------------------------
# SendGrid API Key (recommended for transactional emails)
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.REPLACE_WITH_YOUR_SENDGRID_API_KEY
SENDGRID_FROM_EMAIL=noreply@example.com

# Fallback SMTP configuration (if not using SendGrid)
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# -----------------------------------------------------------------------------
# Stripe (for billing)
# -----------------------------------------------------------------------------
# Use TEST MODE keys for development - get from https://dashboard.stripe.com/test/apikeys
# ⚠️  Never use sk_live_ keys in development!
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_TEST_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_TEST_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# Price IDs - create test products in Stripe dashboard
STRIPE_PRICE_ID_STARTER=price_starter_plan_id
STRIPE_PRICE_ID_PRO=price_pro_plan_id
STRIPE_PRICE_ID_ENTERPRISE=price_enterprise_plan_id

# -----------------------------------------------------------------------------
# GitHub OAuth (for GitHub integration)
# -----------------------------------------------------------------------------
# Create OAuth App: https://github.com/settings/developers
# Homepage URL: https://app.guardrail.network
# Authorization callback URL: https://app.guardrail.network/api/auth/github/callback
GITHUB_CLIENT_ID=REPLACE_WITH_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REPLACE_WITH_GITHUB_CLIENT_SECRET
GITHUB_CALLBACK_URL=https://app.guardrail.network/api/auth/github/callback

# Webhook secret (required for GitHub App webhooks)
GITHUB_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# GitHub App Configuration (for Check Runs and PR Comments)
# Create GitHub App: https://github.com/settings/apps/new
# Webhook URL: https://api.guardrail.network/api/webhooks/github
# Webhook events: pull_request, push, installation, installation_repositories
GITHUB_APP_ID=REPLACE_WITH_GITHUB_APP_ID
GITHUB_APP_PRIVATE_KEY=REPLACE_WITH_GITHUB_APP_PRIVATE_KEY
# Optional: GitHub App OAuth credentials
GITHUB_APP_CLIENT_ID=REPLACE_WITH_GITHUB_APP_CLIENT_ID
GITHUB_APP_CLIENT_SECRET=REPLACE_WITH_GITHUB_APP_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Google OAuth (for Google login)
# -----------------------------------------------------------------------------
# Create OAuth 2.0 Client ID: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized JavaScript origins: https://app.guardrail.network
# Authorized redirect URIs: https://app.guardrail.network/api/auth/google/callback
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=https://app.guardrail.network/api/auth/google/callback

# -----------------------------------------------------------------------------
# OpenAI (optional) - get from https://platform.openai.com/api-keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY

# -----------------------------------------------------------------------------
# Anthropic (optional) - get from https://console.anthropic.com/settings/keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_ANTHROPIC_KEY

# -----------------------------------------------------------------------------
# Sentry Error Tracking (optional for development)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# -----------------------------------------------------------------------------
# Security Logging (optional)
# -----------------------------------------------------------------------------
# External endpoint for security event logging (Datadog, Splunk, etc.)
SECURITY_LOG_ENDPOINT=
SECURITY_LOG_API_KEY=

# External endpoint for CSP violation reports
CSP_REPORT_ENDPOINT=

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
ENABLE_METRICS=false
ENABLE_AI_FEATURES=true
GUARDRAIL_DEMO_MODE=false
GUARDRAIL_POLICY_STRICT=false

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# =============================================================================
# Multi-Factor Authentication (MFA)
# =============================================================================
# Encryption key for MFA secrets (32-byte hex string)
# Pre-generated for production - generate new with: openssl rand -hex 32
# ⚠️  CRITICAL: Generate unique key for each environment!
MFA_ENCRYPTION_KEY=1a68a13c61b7a5bf524eceec91b08a5d13ea0c8d56f855341b0b3c6da50a8a48

# =============================================================================
# PRODUCTION SAFETY: The following vars BLOCK dangerous operations in production
# =============================================================================
# ALLOW_DB_PUSH=true is FORBIDDEN in production (start.sh will exit)
# Use 'prisma migrate deploy' instead of 'db push' in production
