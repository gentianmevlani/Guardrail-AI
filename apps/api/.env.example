# Database
DATABASE_URL=postgresql://user:password@localhost:5432/guardrail

# Auth
JWT_SECRET=change-me-min-32-chars-use-openssl-rand-base64-32

# Public URL of the web app (emails, Stripe redirects, OAuth)
FRONTEND_URL=http://localhost:5001

# OAuth — must match the Next.js web-ui callback URLs when using /api/auth/*/callback there
# Google: authorized redirect in Google Cloud Console = {FRONTEND_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:5001/api/auth/google/callback
# GitHub OAuth App callback = {FRONTEND_URL}/api/auth/github/callback
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:5001/api/auth/github/callback

# Stripe — same secret key as web-ui if both create sessions / verify webhooks
STRIPE_SECRET_KEY=sk_test_XXXXXXXX

# Webhook signing secret from Stripe Dashboard → Developers → Webhooks → endpoint → Signing secret
# Or from `stripe listen` output when testing locally
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX

# Optional API version override (default 2023-10-16)
# STRIPE_API_VERSION=2023-10-16

# Map subscription prices to tiers (comma-separated allowed for multiple price IDs per tier)
STRIPE_PRICE_ID_STARTER=price_XXXXXXXX
STRIPE_PRICE_ID_PRO=price_XXXXXXXX
STRIPE_PRICE_ID_COMPLIANCE=price_XXXXXXXX

# Optional monthly/annual explicit IDs for webhook matching
# STRIPE_PRICE_ID_STARTER_MONTHLY=price_XXX
# STRIPE_PRICE_ID_STARTER_ANNUAL=price_XXX
# STRIPE_PRICE_ID_PRO_MONTHLY=price_XXX
# STRIPE_PRICE_ID_PRO_ANNUAL=price_XXX
# STRIPE_PRICE_ID_COMPLIANCE_MONTHLY=price_XXX
# STRIPE_PRICE_ID_COMPLIANCE_ANNUAL=price_XXX

# CORS / trusted origins (if needed)
# ALLOWED_ORIGINS=http://localhost:5001
