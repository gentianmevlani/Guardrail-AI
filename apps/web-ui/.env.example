# =============================================================================
# Guardrail Web UI Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values

# =============================================================================
# Local development
# =============================================================================
#
# Optional (dev only): mock signed-in session on /dashboard; does not change `/` — use `/dashboard` for the bypass entry.
# NEXT_PUBLIC_DEV_SKIP_AUTH=true

# =============================================================================
# Analytics & Tracking
# =============================================================================

# Google Analytics 4 Measurement ID
# Get from: Google Analytics > Admin > Data Streams > Web > Measurement ID
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID
# Get from: Meta Events Manager > Data Sources > Pixels
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXXX

# =============================================================================
# API Configuration
# =============================================================================

# Backend API URL (Fastify @guardrail/api — used by client + webhook proxy)
NEXT_PUBLIC_API_URL=http://localhost:4000
# Server-side webhook proxy can use API_URL; falls back to NEXT_PUBLIC_API_URL
API_URL=http://localhost:4000

# Public app URL — used for OAuth and must match Stripe redirect allowlist
# Dev: web-ui runs on port 5001 (5000 is often taken by macOS AirPlay Receiver)
NEXT_PUBLIC_APP_URL=http://localhost:5001

# Server-side redirect base for Stripe Checkout success/cancel (production: required)
# Should match the public URL users use (no trailing slash)
FRONTEND_URL=http://localhost:5001

# =============================================================================
# Authentication
# =============================================================================

# NextAuth Secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:5001

# Local-only mock email/password auth (Next /api/auth/login + register) when you deliberately
# omit NEXT_PUBLIC_API_URL. Never enable in staging/production.
# Requires: NODE_ENV=development, ALLOW_MOCK_AUTH=true, plus both vars below.
# ALLOW_MOCK_AUTH=true
# MOCK_AUTH_EMAIL=dev@example.com
# MOCK_AUTH_PASSWORD=change-me-local-only

# GitHub OAuth (sign-in via Next.js — callback hits this app)
# GitHub App / OAuth App: Authorization callback URL must be exactly:
#   {NEXT_PUBLIC_APP_URL}/api/auth/github/callback
# Same values below should be set on @guardrail/api if you use API-initiated GitHub flows.
GITHUB_CLIENT_ID=your-github-client-id
# Optional: public duplicate for client bundles that read the id (server routes prefer GITHUB_CLIENT_ID)
# NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
# Optional override when the callback URL is not {APP_URL}/api/auth/github/callback
# GITHUB_CALLBACK_URL=https://your-domain.com/api/auth/github/callback

# Google OAuth — Cloud Console OAuth 2.0 Client: add authorized redirect URI:
#   {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
# Optional public id for builds that only expose the client id to the browser
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# =============================================================================
# Stripe (Payments)
# =============================================================================
#
# 1. Create a Stripe account: https://dashboard.stripe.com/register
# 2. Products: create three recurring products (Starter $9.99, Pro $29.99, Compliance $59.99)
#    — or one product with three prices; copy each Price ID (price_...)
# 3. Webhooks: see docs/stripe-setup.md — production URL hits this app’s Next route
#    which forwards to the API. CLI: stripe listen --forward-to localhost:5001/api/webhooks/stripe
#
# Publishable key — only if you add Stripe.js / Elements later (Checkout uses hosted page)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXX

# Secret key — server only; never commit real keys
STRIPE_SECRET_KEY=sk_test_XXXXXXXX

# Optional: override default API version (default 2023-10-16, must match API)
# STRIPE_API_VERSION=2023-10-16

# Price IDs for Checkout (subscriptions) — from Stripe Dashboard → Products → Price
STRIPE_PRICE_ID_STARTER=price_XXXXXXXX
STRIPE_PRICE_ID_PRO=price_XXXXXXXX
STRIPE_PRICE_ID_COMPLIANCE=price_XXXXXXXX

# Optional: legacy name if you still use an Enterprise price for Compliance
# STRIPE_PRICE_ID_ENTERPRISE=price_XXXXXXXX

# Optional: monthly/annual splits for webhook tier mapping (API)
# STRIPE_PRICE_ID_STARTER_MONTHLY=price_XXX
# STRIPE_PRICE_ID_STARTER_ANNUAL=price_XXX
# STRIPE_PRICE_ID_PRO_MONTHLY=price_XXX
# STRIPE_PRICE_ID_PRO_ANNUAL=price_XXX
# STRIPE_PRICE_ID_COMPLIANCE_MONTHLY=price_XXX
# STRIPE_PRICE_ID_COMPLIANCE_ANNUAL=price_XXX

# Webhook signing secret — set on **@guardrail/api** (where signature is verified).
# Next.js /api/webhooks/stripe only forwards the raw body; do not rely on this in web-ui alone.
# STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXX
