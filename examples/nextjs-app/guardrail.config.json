{
  "version": "2.0.0",
  "checks": ["integrity", "security", "hygiene", "contracts"],
  "output": ".guardrail",
  "policy": {
    "failOn": ["critical", "high"],
    "allowlist": {
      "domains": ["api.stripe.com", "api.vercel.com"],
      "packages": [],
      "paths": []
    },
    "ignore": {
      "paths": [".next", "node_modules", "coverage", "__tests__"]
    }
  },
  "profiles": {
    "quick": {
      "checks": ["integrity"]
    },
    "full": {
      "checks": ["integrity", "security", "hygiene", "contracts"]
    }
  }
}
