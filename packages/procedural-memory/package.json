{
  "name": "@guardrail/procedural-memory",
  "version": "0.1.0",
  "description": "Procedural memory, metacognition, and consciousness for Claude Code",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "engram": "dist/cli.js",
    "claude-conscious": "dist/cli.js"
  },
  "files": [
