{
  "name": "@guardrail/database",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc --watch",
    "db:generate": "prisma generate",
    "db:push": "node -e \"if(process.env.NODE_ENV==='production'){console.error('❌ db:push is blocked in production. Use db:migrate:deploy');process.exit(1)}\" && prisma db push",
    "db:push:dev": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:migrate:reset": "node -e \"if(process.env.NODE_ENV==='production'){console.error('❌ db:migrate:reset is blocked in production');process.exit(1)}\" && prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "db:safe-check": "node ../../scripts/db-safe-check.js",
    "db:init": "node ../../scripts/db-init-migration.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0"
  },
  "devDependencies": {
    "prisma": "^5.7.0",
    "typescript": "^5.3.3"
  }
}
