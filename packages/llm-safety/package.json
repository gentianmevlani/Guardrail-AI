{
  "name": "@guardrail/llm-safety",
  "version": "0.1.0",
  "description": "Runtime LLM guardrails — Input, Output, Behavioral, Process engines, SDK, and Fastify API",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./middleware-adapters/express": {
      "types": "./dist/middleware-adapters/express.d.ts",
      "import": "./dist/middleware-adapters/express.js",
      "default": "./dist/middleware-adapters/express.js"
    },
    "./middleware-adapters/langchain": {
      "types": "./dist/middleware-adapters/langchain.d.ts",
      "import": "./dist/middleware-adapters/langchain.js",
      "default": "./dist/middleware-adapters/langchain.js"
    }
  },
  "peerDependencies": {
    "@langchain/core": "^0.3.0",
    "express": "^4.21.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": { "optional": true },
    "express": { "optional": true }
  },
  "bin": {
    "llm-guardrail": "./dist/cli.js"
  },
  "files": ["dist", "config", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/cli.ts serve",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "fastify": "^5.1.0",
    "js-yaml": "^4.1.0",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.26",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "express": "^4.21.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
