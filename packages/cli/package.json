{
  "name": "guardrail-cli-tool",
  "version": "2.5.2",
  "description": "Guardrail CLI - Enterprise security scanning with interactive menu, arrow navigation, and auto-installation",
  "main": "dist/index.js",
  "bin": {
    "guardrail": "dist/index.js",
    "vc": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@guardrail/core": "workspace:*",
    "guardrail-security": "workspace:*",
    "guardrail-ship": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "esbuild": ">=0.25.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "guardrail",
    "security",
    "cli",
    "scanning",
    "vulnerabilities",
    "secrets",
    "sbom",
    "osv",
    "cve",
    "devsecops",
    "sast",
    "supply-chain"
  ],
  "license": "MIT",
  "author": "Guardrail Team <support@guardrailai.dev>",
  "homepage": "https://guardrailai.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guardiavault-oss/codeguard.git"
  },
  "bugs": {
    "url": "https://github.com/guardiavault-oss/codeguard/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
